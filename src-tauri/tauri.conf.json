{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Spy",
  "version": "0.1.1",
  "identifier": "com.xaghoul-games.project-spy",
  "build": {
    "beforeDevCommand": "npm --prefix web run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix web run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Project Spy",
        "width": 1100,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560,
        "backgroundColor": "#021c33"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {}
  }
}
